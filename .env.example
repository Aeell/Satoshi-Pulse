# Satoshi Pulse v2 - Environment Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# ENVIRONMENT
# =============================================================================
ENV=development
DEBUG=false
LOG_LEVEL=INFO

# =============================================================================
# DATABASE
# =============================================================================
# PostgreSQL/TimescaleDB (use DB_USE_SQLITE=true for local dev)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=satoshi_pulse
DB_USER=postgres
DB_PASSWORD=postgres
DB_USE_SQLITE=false
DB_SQLITE_PATH=./data/satoshi_pulse.db

# =============================================================================
# API SERVER
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# =============================================================================
# DATA COLLECTORS
# =============================================================================

# CoinGecko (https://www.coingecko.com/en/api)
COLLECTOR_COINGECKO_ENABLED=true
COLLECTOR_COINGECKO_INTERVAL=300
COINGECKO_API_KEY=CG-7hMam5f5aS3s5HtGWaCrthce

# CoinMarketCap (https://pro.coinmarketcap.com/signup)
COLLECTOR_COINMARKETCAP_ENABLED=true
COLLECTOR_COINMARKETCAP_INTERVAL=3600
COINMARKETCAP_API_KEY=1e8d281ff8804ae1bed4cf421621ab0b

# CCXT Exchanges (Binance, Gate.io, etc.)
COLLECTOR_CCXT_ENABLED=true
COLLECTOR_CCXT_INTERVAL=60
CCXT_BINANCE_API_KEY=your_binance_api_key
CCXT_BINANCE_SECRET=your_binance_secret
CCXT_BINANCE_TESTNET=true
CCXT_GATE_API_KEY=your_gate_api_key
CCXT_GATE_SECRET=your_gate_secret

# CoinMetrics (https://community-api.coinmetrics.io — free, no key needed)
COLLECTOR_COINMETRICS_ENABLED=true
COLLECTOR_COINMETRICS_INTERVAL=86400

# Santiment (https://app.santiment.net)
COLLECTOR_SANTIMENT_ENABLED=false
COLLECTOR_SANTIMENT_INTERVAL=21600
SANTIMENT_API_KEY=your_santiment_api_key

# DefiLlama (https://api.llama.fi)
COLLECTOR_DEFILLAMA_ENABLED=true
COLLECTOR_DEFILLAMA_INTERVAL=21600

# DexScreener (https://api.dexscreener.com)
COLLECTOR_DEXSCREENER_ENABLED=true
COLLECTOR_DEXSCREENER_INTERVAL=300

# Coinalyze (https://coinalyze.net/api/)
COLLECTOR_COINALYZE_ENABLED=true
COLLECTOR_COINALYZE_INTERVAL=900
COINALYZE_API_KEY=your_coinalyze_api_key

# Fear & Greed Index (https://api.alternative.me/fng/)
COLLECTOR_FEAR_GREED_ENABLED=true
COLLECTOR_FEAR_GREED_INTERVAL=3600

# CryptoPanic (https://cryptopanic.com/api/)
COLLECTOR_CRYPTOPANIC_ENABLED=true
COLLECTOR_CRYPTOPANIC_INTERVAL=3600
CRYPTOPANIC_API_KEY=your_cryptopanic_api_key

# Whale Alert (https://whale-alert.io/)
COLLECTOR_WHALE_ALERT_ENABLED=true
COLLECTOR_WHALE_ALERT_INTERVAL=900
WHALE_ALERT_API_KEY=your_whale_alert_api_key

# Messari (https://messari.io/api)
COLLECTOR_MESSARI_ENABLED=true
COLLECTOR_MESSARI_INTERVAL=86400
MESSARI_API_KEY=your_messari_api_key

# =============================================================================
# FREQTRADE
# =============================================================================
FREQTRADE_HOST=localhost
FREQTRADE_PORT=8080
FREQTRADE_WS_PORT=8081
FREQTRADE_API_KEY=your_freqtrade_api_key
FREQTRADE_RPC_URL=http://localhost:8080
FREQTRADE_STRATEGY_MODE=webhook

# Exchange API Keys (for Freqtrade)
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET=your_binance_secret
GATE_API_KEY=your_gate_api_key
GATE_SECRET=your_gate_secret

# Trading Settings
FREQTRADE_DRY_RUN=true
FREQTRADE_MAX_POSITION_SIZE=0.02
FREQTRADE_MAX_TOTAL_EXPOSURE=0.20
FREQTRADE_MAX_DAILY_LOSS=0.05
FREQTRADE_MAX_CONSECUTIVE_LOSSES=3

# =============================================================================
# DASHBOARD
# =============================================================================
DASHBOARD_PORT=3000
DASHBOARD_API_URL=http://localhost:8000